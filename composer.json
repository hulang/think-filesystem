{
    "name": "hulang/think-filesystem",
    "description": "The ThinkPHP6 filesystem driver Package,include Aliyun、Qiniu、qcloud、obs、s3、ftp、sftp",
    "type": "library",
    "require": {
        "ext-ftp": "*",
        "php": ">=7.2.0",
        "topthink/framework": "^6.0.0",
        "yzh52521/flysystem-oss": "^1.0",
        "overtrue/flysystem-qiniu": "^1.0",
        "overtrue/flysystem-cos": "^2.0.0",
        "yzh52521/flysystem-obs": "^1.0",
        "league/flysystem-aws-s3-v3":"^1.0",
        "league/flysystem-sftp": "^1.0.0"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "hulang",
            "email": "hulangfy@163.com"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "hulang\\filesystem\\": "src/"
        }
    },
    "extra": {
        "think": {
            "services": [
                "hulang\\filesystem\\Service"
            ]
        }
    }
}
